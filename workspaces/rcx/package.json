{
  "name": "@blinkorb/rcx",
  "version": "0.1.2",
  "description": "Reactive JSX-based library for creating HTML5 canvas applications",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./canvas": {
      "import": "./src/components/canvas/index.ts"
    },
    "./components": {
      "import": "./src/components/index.ts"
    },
    "./context": {
      "import": "./src/context/index.ts"
    },
    "./hooks": {
      "import": "./src/hooks/index.ts"
    },
    "./utils": {
      "import": "./src/utils/index.ts"
    },
    "./jsx-runtime": {
      "import": "./src/jsx-runtime.ts"
    },
    "./jsx-dev-runtime": {
      "import": "./src/jsx-dev-runtime.ts"
    }
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "tsb serve",
    "dist": "npm run build",
    "build": "rm -rf dist && tsc -p tsconfig.dist.json --rewriteRelativeImportExtensions && tsx ../../scripts/prep-package.ts && cp README.md ../../LICENSE.txt dist/",
    "type-check": "tsc --noEmit",
    "format-check": "prettier --check *",
    "format-fix": "prettier --write *",
    "lint-check": "eslint '**/*.{ts,tsx,js,jsx}'",
    "lint-fix": "eslint '**/*.{ts,tsx,js,jsx}' --fix",
    "tests": "jest --coverage --runInBand",
    "test": "npm run format-check && npm run type-check && npm run lint-check && npm run tests",
    "prepublishOnly": "npm run test && npm run dist && echo 'Now run publish from the dist directory' && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blinkorb/rcx.git"
  },
  "keywords": [
    "canvas",
    "jsx",
    "view",
    "library",
    "reactive",
    "html5",
    "game"
  ],
  "author": "BlinkOrb",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/blinkorb/rcx/issues"
  },
  "homepage": "https://github.com/blinkorb/rcx#readme",
  "devDependencies": {
    "@blinkorb/eslint-config-rcx-dev": "^0.0.0",
    "@jakesidsmith/tsb": "^3.0.2",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}

{
  "name": "@blinkorb/rcx-react",
  "version": "0.0.0",
  "description": "Utilities for using RCX within React applications",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "tsb serve",
    "dist": "npm run build",
    "build": "rm -rf dist && tsc -p tsconfig.dist.json --rewriteRelativeImportExtensions && tsx ../../scripts/prep-package.ts && cp README.md dist/README.md",
    "type-check": "tsc --noEmit",
    "format-check": "prettier --check *",
    "format-fix": "prettier --write *",
    "lint-check": "eslint '**/*.{ts,tsx,js,jsx}'",
    "lint-fix": "eslint '**/*.{ts,tsx,js,jsx}' --fix",
    "tests": "jest --coverage --runInBand",
    "test": "npm run format-check && npm run type-check && npm run lint-check && npm run tests",
    "prepublishOnly": "npm run test && npm run dist && echo 'Now run publish from the dist directory' && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blinkorb/rcx.git"
  },
  "keywords": [
    "canvas",
    "jsx",
    "view",
    "library",
    "reactive",
    "html5",
    "game",
    "react"
  ],
  "author": "BlinkOrb",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/blinkorb/rcx/issues"
  },
  "homepage": "https://github.com/blinkorb/rcx#readme",
  "dependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@blinkorb/eslint-config-rcx-dev": "^0.0.0",
    "@jakesidsmith/tsb": "^3.0.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
